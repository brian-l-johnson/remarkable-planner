        "text": "={{ 'Write one short motivational sentence (~20 words) summarizing what needs to be done on this day. Day: ' + $now.format('EEEE') + '. Weather: ' + $json.weather_condition + ', ' + $json.weather_high + '°F high. Events: ' + ($json.events.length ? $json.events.map(e => e.title).join(', ') : 'no scheduled events') + '. Tasks: ' + ($json.todos.length ? $json.todos.map(t => t.text).join(', ') : 'no tasks') + '. Reply with ONLY the sentence, no quotes.' }}",
