    {
      "parameters": {
        "jsCode": "const condition = $('HA: Weather Condition').first().json;\nconst high      = $('HA: Weather High').first().json;\nconst low       = $('HA: Weather Low').first().json;\n\nfunction parseLocalTime(dt, tz) {\n  if (dt.endsWith('Z')) {\n    const d = new Date(dt);\n    const local = new Intl.DateTimeFormat('en-US', {\n      timeZone: 'America/Chicago',  // always convert to Chicago, ignore event's tz field\n      hour: 'numeric',\n      minute: 'numeric',\n      hour12: false,\n    }).format(d);\n    const [h, m] = local.split(':').map(Number);\n    return { hours: h, minutes: m };\n  }\n  const t = dt.split('T')[1];\n  return { hours: parseInt(t.slice(0,2), 10), minutes: parseInt(t.slice(3,5), 10) };\n}\n\nconst colors = ['cal-blue', 'cal-green', 'cal-amber'];\n\nconst calItems = [\n  ...$('Google Calendar: Today').all(),\n  ...$('Google Calendar: Family').all(),\n].filter((item, idx, arr) =>\n  arr.findIndex(i => i.json.id === item.json.id) === idx\n);\n\nconst events = calItems\n  .filter(item => item.json.start?.dateTime)\n  .map((item, idx) => {\nconst start = parseLocalTime(item.json.start.dateTime, item.json.start.timeZone);\nconst end   = parseLocalTime(item.json.end.dateTime,   item.json.end.timeZone);\n    return {\n      title:      item.json.summary || '(No title)',\n      start_hour: start.hours,\n      start_min:  start.minutes,\n      end_hour:   end.hours,\n      end_min:    end.minutes,\n      color:      colors[idx % colors.length],\n    };\n  })\n  .filter(ev => ev.start_hour >= 7 && ev.start_hour < 20)\n  .sort((a, b) => (a.start_hour * 60 + a.start_min) - (b.start_hour * 60 + b.start_min));\n\n\nconst todoItems = $('HTTP Request').first().json\n  .service_response?.['todo.tasks']?.items ?? [];\n\nconst todos = todoItems\n  .filter(item => item.status !== 'completed')\n  .map(item => ({\n    text:     item.summary,\n    done:     item.status === 'completed',\n    priority: false,\n  }));\n\nreturn [{\n  json: {\n    weather_condition: condition.state || '',\n    weather_high:      Math.round(parseFloat(high.state)) || '',\n    weather_low:       Math.round(parseFloat(low.state))  || '',\n    events,\n    todos: todos,\n  }\n}];"
      },
